ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
MAX_CONNECTIONS=100
WS_HEARTBEAT_INTERVAL=30
ALLOWED_ORIGINS=["http://localhost:5173"]
RATE_LIMIT_WS_CONNECTIONS_PER_IP=5
RATE_LIMIT_WS_MESSAGES_PER_MINUTE=120
SESSION_MAX_LIFETIME_SECONDS=3600
SESSION_IDLE_TIMEOUT_SECONDS=300
LLM_BASE_URL=https://ai.nomineelife.com
LLM_MODEL=your-model-name
LLM_TIMEOUT_SECONDS=60
LLM_API_KEY=
LLM_MAX_TOKENS_PER_REQUEST=1000
MAX_TOKENS_PER_SESSION=8000
MAX_REQUEST_DURATION_SECONDS=60
TTS_ENABLED=true
TTS_VOICE=en-US-AriaNeural
TTS_MAX_BUFFER_CHARS=150
TTS_AUDIO_CHUNK_SIZE=32768
TTS_TIMEOUT_SECONDS=30
MAX_AUDIO_QUEUE_LENGTH=10
LIPSYNC_ENABLED=true
LIPSYNC_MAX_CONCURRENT_PROCESSES=5
LIPSYNC_TIMEOUT_SECONDS=10
RHUBARB_BINARY_PATH=rhubarb
MAX_PHONEME_FRAMES_PER_FLUSH=1500
